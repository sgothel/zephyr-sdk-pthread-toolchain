#
# Target optimisations
#
CT_TARGET_CFLAGS="-moverride=tune=no_ldp_stp_qregs -ftls-model=local-exec -I${CT_TOP_DIR}/temp/include/inject/zephyr -I${CT_TOP_DIR}/temp/include/inject/aarch64-zephyr-elf"
CT_TARGET_LDFLAGS=""
# end of Target options

CT_ARCH_ARM=y
CT_ARCH_64=y

#
# Generic target options
#
CT_MULTILIB=y
CT_MULTILIB_SPACE=y

CT_LIBC_NEWLIB_NANO_TARGET_CFLAGS=""

# GDB
CT_GDB_CROSS_EXTRA_CONFIG_ARRAY="--enable-targets=arm-zephyr-eabi --enable-tls --enable-threads=posix --enable-libstdcxx-threads"

# GCC
CT_CC_GCC_EXTRA_CONFIG_ARRAY="--with-gnu-ld --with-gnu-as --enable-initfini-array --enable-tls --enable-threads=posix --enable-libstdcxx-threads"
CT_CC_GCC_CORE_EXTRA_CONFIG_ARRAY="--with-gnu-ld --with-gnu-as --enable-initfini-array --enable-tls --enable-threads=posix --enable-libstdcxx-threads"
CT_CC_GCC_ENABLE_CXX_FLAGS="-I${CT_TOP_DIR}/temp/include/inject/zephyr -I${CT_TOP_DIR}/temp/include/inject/aarch64-zephyr-elf"

# Binutils
CT_BINUTILS_EXTRA_CONFIG_ARRAY="--disable-warn-rwx-segments"

