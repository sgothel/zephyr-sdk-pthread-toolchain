#ClangTidy config is merged w/ .clang-tidy where this file takes precedence
#Diagnostics:
#  ClangTidy:
#    Add: [clang-diagnostic-*, clang-analyzer-*, modernize-*, bugprone-*]
#
#    Remove: [modernize-use-auto, modernize-use-nodiscard, modernize-use-using, modernize-use-trailing-return-type,
#             modernize-avoid-c-arrays, modernize-use-default-member-init, modernize-return-braced-init-list,
#             modernize-avoid-bind, modernize-use-transparent-functors,
#             bugprone-reserved-identifier, bugprone-easily-swappable-parameters, bugprone-assignment-in-if-condition,
#             bugprone-misplaced-widening-cast, bugprone-branch-clone]
#
#    CheckOptions:
#        modernize-use-default-member-init.UseAssignment: true

# find_path(ZEPHYR_SYS_INC0 kernel.h PATHS "${ZEPHYR_BASE}/include/zephyr" REQUIRED)
# find_path(ZEPHYR_SYS_INC1 pthread.h PATHS "${ZEPHYR_BASE}/include/zephyr/posix" REQUIRED)

Index:
  Background: Build
  StandardLibrary: No

# Tell clangd to use the compile_commands.json file in the build/default folder
CompileFlags:
  CompilationDatabase: @CMAKE_CURRENT_BINARY_DIR@
  Add: [-pedantic, -pedantic-errors, -Wall, -Wextra, -Werror, -DDEBUG, -std=c++20,
        -DCCXXRTT_OS="zephyr", -DCCXXRTT_CPUARCH="armv8m", -DCCXXRTT_ENABLE_PTHREAD_TESTS, -DCCXXRTT_ENABLE_STLTHREADING_TESTS,
        -DCCXXRTT_ENABLE_CPP_TESTS, -DCCXXRTT_ENABLE_POSIX_TESTS, -DCCXXRTT_ENABLE_STLCHRONO_TESTS, -DCCXXRTT_OS_ZEPHYR, -DKERNEL, -DK_HEAP_MEM_POOL_SIZE=512, -DPICOLIBC_LONG_LONG_PRINTF_SCANF, -DZVFS_OPEN_SIZE=4, -D_POSIX_CLOCK_SELECTION=200809L, -D_POSIX_CPUTIME=200809L, -D_POSIX_C_SOURCE=200809L, -D_POSIX_MONOTONIC_CLOCK=200809L, -D_POSIX_MULTI_PROCESS=200809L, -D_POSIX_REALTIME_SIGNALS=200809L, -D_POSIX_THREADS=200809L, -D_POSIX_THREAD_SAFE_FUNCTIONS=200809L, -D_POSIX_TIMERS=200809L, -D__LINUX_ERRNO_EXTENSIONS__, -D__PROGRAM_START, -D__ZEPHYR__=1,
        -imacros, @CMAKE_CURRENT_BINARY_DIR@/zephyr/include/generated/zephyr/autoconf.h,
        -imacros, @ZEPHYR_BASE@/include/zephyr/toolchain/zephyr_stdint.h,
        -I, @CMAKE_CURRENT_BINARY_DIR@/zephyr/include/generated/zephyr,
        -I, @ZEPHYR_BASE@/kernel/include,
        -I, @ZEPHYR_BASE@/include,
        -I, @CMAKE_CURRENT_BINARY_DIR@/zephyr/include/generated,
        -I, @ZEPHYR_BASE@/soc/arm,
        -I, @ZEPHYR_BASE@/lib/libc/picolibc/include,
        -I, @ZEPHYR_BASE@/soc/arm/mps2,
        -I, @ZEPHYR_BASE@/subsys/portability/posix/c_lib_ext/getopt,
        -I, @ZEPHYR_BASE@/include/zephyr/posix,
        -I, @ZEPHYR_BASE@/kernel/include,
        -I, @ZEPHYR_BASE@/arch/arm/include,
        -I, @ZEPHYR_BASE@/subsys/tracing/include,
        -I, @ZEPHYR_BASE@/subsys/tracing/user,
        -I, @ZEPHYR_BASE@/../modules/hal/cmsis_6/CMSIS/Core/Include,
        -I, @ZEPHYR_BASE@/modules/cmsis_6,
        -isystem, @ZEPHYR_BASE@/lib/libc/common/include,
        -isystem, @TOOLCHAIN_C_SYSINC@,
        -I, @TOOLCHAIN_C_INC@,
        -I, @TOOLCHAIN_CXX_INC0@,
        -I, @TOOLCHAIN_CXX_INC1@,
        -I, @ZEPHYR_BASE@/subsys/portability/posix/options,
        -I, @ZEPHYR_BASE@/kernel,
        -I, @ZEPHYR_BASE@/kernel/sys,
        -I, @ZEPHYR_BASE@/kernel/userspace,
        -I, @PROJECT_REPO_ROOT@/include
        ]

Diagnostics:
  UnusedIncludes: Strict
  ClangTidy:
    FastCheckFilter: Loose

InlayHints:
  Enabled: Yes
  BlockEnd: Yes
  Designators: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  TypeNameLimit: 24

Hover:
  ShowAKA: Yes
