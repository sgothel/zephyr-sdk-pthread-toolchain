include_guard(GLOBAL)

#
# PROJECT_REPO_ROOT must point to this file's parent directory
#
macro(ClangdSetup)
find_path(ZEPHYR_SYS_INC0 kernel.h PATHS "${ZEPHYR_BASE}/include/zephyr" REQUIRED)
find_path(ZEPHYR_SYS_INC1 pthread.h PATHS "${ZEPHYR_BASE}/include/zephyr/posix" REQUIRED)
cmake_path(GET CMAKE_C_COMPILER PARENT_PATH TOOLCHAIN_ROOT)
cmake_path(GET TOOLCHAIN_ROOT PARENT_PATH TOOLCHAIN_ROOT)
cmake_path(GET TOOLCHAIN_ROOT FILENAME TOOLCHAIN_TARGET_TRIPLET)
find_path(TOOLCHAIN_C_SYSINC stdio.h PATHS "${TOOLCHAIN_ROOT}/${TOOLCHAIN_TARGET_TRIPLET}/sys-include" REQUIRED)
find_path(TOOLCHAIN_C_INC stdio.h PATHS "${TOOLCHAIN_ROOT}/${TOOLCHAIN_TARGET_TRIPLET}/include" REQUIRED)
set(TEMP_PRE "${TOOLCHAIN_ROOT}/${TOOLCHAIN_TARGET_TRIPLET}/include/c++")
# message(STATUS "TEMP_PRE ${TEMP_PRE}")
file(GLOB_RECURSE TEMP_SUB0 RELATIVE "${TEMP_PRE}" "${TEMP_PRE}/*/iostream")
cmake_path(GET TEMP_SUB0 PARENT_PATH TEMP_SUB1)
set(TOOLCHAIN_CXX_INC0 "${TEMP_PRE}/${TEMP_SUB1}")
set(TOOLCHAIN_CXX_INC1 "${TOOLCHAIN_CXX_INC0}/${TOOLCHAIN_TARGET_TRIPLET}")
unset(TEMP_PRE)
unset(TEMP_SUB0)
unset(TEMP_SUB1)
message(STATUS "..")
message(STATUS "CMAKE_CURRENT_SOURCE_DIR: ${CMAKE_CURRENT_SOURCE_DIR}")
message(STATUS "..")
message(STATUS "ZEPHYR_BASE: ${ZEPHYR_BASE}")
message(STATUS "ZEPHYR_SDK_INSTALL_DIR: ${ZEPHYR_SDK_INSTALL_DIR}")
message(STATUS "..")
message(STATUS "CMAKE_C_COMPILER: ${CMAKE_C_COMPILER}")
message(STATUS "CMAKE_CXX_COMPILER: ${CMAKE_CXX_COMPILER}")
message(STATUS "CMAKE_C_COMPILER: ${CMAKE_C_COMPILER}")
message(STATUS "..")
message(STATUS "ZEPHYR_SYS_INC0: ${ZEPHYR_SYS_INC0}")
message(STATUS "ZEPHYR_SYS_INC1: ${ZEPHYR_SYS_INC1}")
message(STATUS "TOOLCHAIN_ROOT: ${TOOLCHAIN_ROOT}")
message(STATUS "TOOLCHAIN_TARGET_TRIPLET: ${TOOLCHAIN_TARGET_TRIPLET}")
message(STATUS "TOOLCHAIN_C_SYSINC: ${TOOLCHAIN_C_SYSINC}")
message(STATUS "TOOLCHAIN_C_INC: ${TOOLCHAIN_C_INC}")
message(STATUS "TOOLCHAIN_CXX_INC0: ${TOOLCHAIN_CXX_INC0}")
message(STATUS "TOOLCHAIN_CXX_INC1: ${TOOLCHAIN_CXX_INC1}")
message(STATUS "..")

# Fixup clangd w/ absolute path
configure_file (${PROJECT_REPO_ROOT}/cmake/clangd.in
                ${CMAKE_CURRENT_BINARY_DIR}/.clangd)
file(COPY_FILE ${CMAKE_CURRENT_BINARY_DIR}/.clangd ${CMAKE_CURRENT_SOURCE_DIR}/.clangd RESULT COPY_ERR)

endmacro()
